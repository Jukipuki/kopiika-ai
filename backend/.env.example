LLM_PROVIDER=anthropic  # anthropic | openai | bedrock — bedrock wiring lands in Story 9.5b

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/kopiika_db

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS
AWS_REGION=eu-central-1

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_REGION=eu-central-1
COGNITO_BACKEND_CLIENT_ID=
COGNITO_BACKEND_CLIENT_SECRET=

# S3
S3_BUCKET_NAME=kopiika-uploads-dev

# SES
SES_SENDER_EMAIL=

# Secrets Manager prefix (kopiika/{env})
AWS_SECRETS_PREFIX=kopiika/dev

# Deployment environment — gates local-only crypto fallback. Never set to 'local' outside dev.
ENV=local

# KMS CMK ARN for IBAN envelope encryption (Story 11.10). Required when ENV != 'local'.
# Example: arn:aws:kms:eu-central-1:123456789012:key/abcd1234-...
KMS_IBAN_KEY_ARN=

# Story 11.8 three-tier categorization thresholds:
#   >= AUTO_APPLY: silent accept
#   [SOFT_FLAG, AUTO_APPLY): accept + telemetry
#   < SOFT_FLAG: route to review queue
CATEGORIZATION_SOFT_FLAG_THRESHOLD=0.6
CATEGORIZATION_AUTO_APPLY_THRESHOLD=0.85

# Local-dev Fernet key for IBAN encryption (urlsafe-b64-encoded 32 bytes).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NEVER set in staging/prod — KMS_IBAN_KEY_ARN is authoritative there.
LOCAL_IBAN_FERNET_KEY=

# Story 10.4a chat runtime phasing (ADR-0004). 'direct' = Phase A bedrock-runtime
# via llm.py; 'agentcore' = Phase B AgentCore container (not yet shipped).
CHAT_RUNTIME=direct
# Bedrock AgentCore runtime ARN — populated only in Phase B prod; None otherwise.
AGENTCORE_RUNTIME_ARN=
# Bedrock Guardrail ARN from Story 10.2; attached to chat by Story 10.5.
BEDROCK_GUARDRAIL_ARN=
# Per-session memory bounds (architecture.md — 20 turns or 8k tokens, whichever first).
CHAT_SESSION_MAX_TURNS=20
CHAT_SESSION_MAX_TOKENS=8000
# Turns retained verbatim on summarization trigger; older ones collapse to a summary row.
CHAT_SUMMARIZATION_KEEP_RECENT_TURNS=6

# Story 10.4b chat prompt-leak defense.
# Secrets Manager name for the chat canary tokens. Unset → loader constructs
# f"{AWS_SECRETS_PREFIX}/chat-canaries" at first call.
CHAT_CANARIES_SECRET_ID=
# Single-source-of-truth for the input validator length cap (per-user-message chars).
CHAT_INPUT_MAX_CHARS=4000
# In-process TTL for the canary cache; operator rotation via put-secret-value
# propagates within this window. 900s (15 min) aligns with the monthly rotation cadence.
CHAT_CANARY_CACHE_TTL_SECONDS=900
