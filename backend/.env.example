# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/kopiika_db

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS
AWS_REGION=eu-central-1

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_REGION=eu-central-1
COGNITO_BACKEND_CLIENT_ID=
COGNITO_BACKEND_CLIENT_SECRET=

# S3
S3_BUCKET_NAME=kopiika-uploads-dev

# SES
SES_SENDER_EMAIL=

# Secrets Manager prefix (kopiika/{env})
AWS_SECRETS_PREFIX=kopiika/dev

# Deployment environment — gates local-only crypto fallback. Never set to 'local' outside dev.
ENV=local

# KMS CMK ARN for IBAN envelope encryption (Story 11.10). Required when ENV != 'local'.
# Example: arn:aws:kms:eu-central-1:123456789012:key/abcd1234-...
KMS_IBAN_KEY_ARN=

# Story 11.8 three-tier categorization thresholds:
#   >= AUTO_APPLY: silent accept
#   [SOFT_FLAG, AUTO_APPLY): accept + telemetry
#   < SOFT_FLAG: route to review queue
CATEGORIZATION_SOFT_FLAG_THRESHOLD=0.6
CATEGORIZATION_AUTO_APPLY_THRESHOLD=0.85

# Local-dev Fernet key for IBAN encryption (urlsafe-b64-encoded 32 bytes).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NEVER set in staging/prod — KMS_IBAN_KEY_ARN is authoritative there.
LOCAL_IBAN_FERNET_KEY=
