# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/kopiika_db

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS
AWS_REGION=eu-central-1

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

# S3
S3_BUCKET_NAME=kopiika-uploads-dev

# SES
SES_SENDER_EMAIL=

# Secrets Manager prefix (kopiika/{env})
AWS_SECRETS_PREFIX=kopiika/dev
